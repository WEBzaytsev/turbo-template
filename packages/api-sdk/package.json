{
  "name": "@repo/api-sdk",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist .turbo",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@nestia/fetcher": "11.0.2",
    "typia": "12.0.2"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "rimraf": "6.1.3",
    "tsup": "8.5.1",
    "typescript": "5.9.3"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  }
}
